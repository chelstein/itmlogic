# Genoa — environment template.  Copy to .env, fill secrets locally,
# never commit real values.

# ---------- Core ----------
NODE_ENV=development
PORT=8080

# ---------- Postgres ----------
# Stateless mode (DATABASE_URL empty) is supported: compute / exports
# work, persistence routes return 503.
DATABASE_URL=postgres://genoa:genoa@localhost:5432/genoa
PG_SSL=false
PG_SSL_REJECT=false

# ---------- Object storage (S3-compatible: DigitalOcean Spaces) ----------
SPACES_ENDPOINT=
SPACES_BUCKET=
SPACES_ACCESS_KEY_ID=
SPACES_SECRET_ACCESS_KEY=

# ---------- Sidecars (all optional) ----------
TERRAIN_SIDECAR_URL=
MEASUREMENT_SIDECAR_URL=
IDENTITY_SIDECAR_URL=

# ---------- SPLAT sidecar (optional) ----------
# Wraps chelstein/splat's Genoa Flask sidecar (POST /api/v1/splat/run).
# When set, Genoa probes the sidecar's health + version and stamps
# evidence.splat with {available, source, endpoint, sidecar_name,
# splat_bin, workdir, dem_provisioned, note}.  Engineering output via
# SPLAT (terrain-aware ITM contour, per-radial HAAT) requires DEM tiles
# provisioned in the sidecar's WORKDIR; the wiring is in place so that
# switching the engine over is a single change once tiles are mounted.
SPLAT_SIDECAR_URL=

# ---------- Read-only upstreams ----------
# zerotrustradio is the primary FCC facility data source for Genoa's
# /api/facilities/{search,:id} adapter.  It MUST be the read-only
# instance — Genoa never writes back.
ZERO_TRUST_RADIO_READONLY_URL=
RADIODNS_RESOLVER_URL=

# ---------- n8n webhook (optional facility fallback) ----------
# When set, Genoa will fall back to the existing n8n station/analyze
# workflow if zerotrustradio is unreachable for a /api/facilities lookup.
N8N_BASE_URL=
N8N_WEBHOOK_SECRET=

# ---------- Sourced population evidence ----------
# Optional.  When set, Genoa POSTs the service-grade contour GeoJSON to
# {URL}/v1/population/contour and expects a fully validated record:
# { persons, source, vintage, method, fetched_at } at minimum.
# If unset, Genoa keeps POPULATION_PLACEHOLDER honestly.
POPULATION_EVIDENCE_URL=

# ---------- SDR evidence service gate ----------
# CSV of service codes (FM | AM | LPFM | FX) for which SDR captures
# should be pulled from ZTR's _captures field.  ZTR currently captures
# AM only; pulling FM "captures" today would attach noise as evidence.
# Default: AM.  Flip to "AM,FM" once FM-band capture coverage exists.
SDR_EVIDENCE_SERVICES=AM

# ---------- Sidecar-internal (only relevant when running a sidecar) ----------
TERRAIN_BACKEND=                 # splat | itmlogic | ztrpsits
SPLAT_BIN=splat
ITMLOGIC_BIN=python3 -m itmlogic
ZTRPSITS_BIN=ztrpsits
EAS_TOOLS_URL=
MASSDNS_RESOLVER_URL=

# ---------- Worker ----------
WORKER_POLL_MS=5000

# ---------- Build/audit ----------
# Set by CI / Docker build.  Used to populate exhibit.engine_signature.hash.
GIT_COMMIT_SHA=
