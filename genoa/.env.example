# Genoa — local dev environment template. Copy to .env.

PORT=8080
NODE_ENV=development

# Postgres
DATABASE_URL=postgres://genoa:genoa@localhost:5432/genoa
PG_SSL=false
PG_SSL_REJECT=false

# Digital Ocean Spaces (S3-compatible). Optional for local dev — without
# these, asset uploads return 503 but the deterministic engine still runs.
SPACES_REGION=nyc3
SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
SPACES_BUCKET=genoa-exhibits
SPACES_KEY=
SPACES_SECRET=

# ---- Terrain DEM provider (per-radial HAAT, §73.313) ---------------
# Default is the public Open-Elevation API (no key, free, rate-limited).
# Swap in OpenTopoData or a self-hosted instance for higher throughput
# / SRTM-1 fidelity. Genoa caches every queried (lat, lon) in
# genoa_terrain_cache so repeated computes near the same site are free.
TERRAIN_PROVIDER=open-elevation
OPEN_ELEVATION_URL=https://api.open-elevation.com/api/v1/lookup
TERRAIN_BATCH_LIMIT=512
TERRAIN_TIMEOUT_MS=20000
